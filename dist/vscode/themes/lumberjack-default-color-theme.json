{
  "$schema": "vscode://schemas/color-theme",
  "name": "Lumberjack default",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "foreground": "#81f0fe",
    "focusBorder": "#e95d74",
    "editor.background": "#00171a",
    "editor.foreground": "#4eeafe",
    "editorLineNumber.foreground": "#009eb380",
    "editorLineNumber.activeForeground": "#00e2ff",
    "editorCursor.foreground": "#e95d74",
    "editor.selectionBackground": "#e95d7440",
    "editor.findMatchBackground": "#f1d8684d",
    "editor.lineHighlightBackground": "#002e344d",
    "activityBar.background": "#002e34",
    "activityBar.foreground": "#81f0fe",
    "sideBar.background": "#000d0f",
    "sideBar.foreground": "#81f0fe",
    "statusBar.background": "#002e34",
    "statusBar.foreground": "#81f0fe",
    "panel.background": "#000d0f",
    "panel.border": "#000000b3",
    "button.background": "#003942",
    "button.foreground": "#00171a",
    "input.background": "#002329",
    "input.foreground": "#81f0fe",
    "terminal.background": "#00171a",
    "terminal.foreground": "#81f0fe",
    "terminal.ansiBlack": "#000000",
    "terminal.ansiRed": "#ec5342",
    "terminal.ansiGreen": "#f75f94",
    "terminal.ansiYellow": "#f1d868",
    "terminal.ansiBlue": "#82f0ff",
    "terminal.ansiMagenta": "#f75f94",
    "terminal.ansiCyan": "#f1d868",
    "terminal.ansiWhite": "#FFFFFF",
    "terminal.ansiBrightBlack": "#00889a",
    "terminal.ansiBrightRed": "#f17d70",
    "terminal.ansiBrightGreen": "#f990b4",
    "terminal.ansiBrightYellow": "#f5e497",
    "terminal.ansiBrightBlue": "#b5f6ff",
    "terminal.ansiBrightMagenta": "#f990b4",
    "terminal.ansiBrightCyan": "#f5e497",
    "terminal.ansiBrightWhite": "#b4f6fe",
    "gitDecoration.addedResourceForeground": "#60e66f",
    "gitDecoration.modifiedResourceForeground": "#f1d868",
    "gitDecoration.deletedResourceForeground": "#e61e3f",
    "editorError.foreground": "#e61e3f",
    "editorWarning.foreground": "#e3946a",
    "editorInfo.foreground": "#e95d74",
    "editorHint.foreground": "#018799"
  },
  "semanticTokenColors": {
    "class": "#f75f94",
    "enum": "#f75f94",
    "function": "#82f0ff",
    "method": "#82f0ff",
    "namespace": "#82f0ff",
    "parameter": "#eeeeee",
    "property": "#81f0fe",
    "type": "#f75f94",
    "variable": "#eeeeee",
    "variableReadOnly": "#ec5342"
  },
  "tokenColors": [
    {
      "scope": [
        "comment"
      ],
      "settings": {
        "foreground": "#018799"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#f1d868"
      }
    },
    {
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#f75f94"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#ec5342"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#82f0ff"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type"
      ],
      "settings": {
        "foreground": "#f75f94"
      }
    },
    {
      "scope": [
        "variable"
      ],
      "settings": {
        "foreground": "#eeeeee"
      }
    }
  ]
}