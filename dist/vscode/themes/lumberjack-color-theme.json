{
  "$schema": "vscode://schemas/color-theme",
  "name": "Lumberjack default",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "foreground": "#8fe8f4",
    "focusBorder": "#e26a89",
    "editor.background": "#001419",
    "editor.foreground": "#66dbe8",
    "editorLineNumber.foreground": "#1fa9ba80",
    "editorLineNumber.activeForeground": "#59e9fb",
    "editorCursor.foreground": "#e26a89",
    "editor.selectionBackground": "#e26a8940",
    "editor.findMatchBackground": "#e3cb6d4d",
    "editor.lineHighlightBackground": "#00242b66",
    "activityBar.background": "#00242b",
    "activityBar.foreground": "#8fe8f4",
    "sideBar.background": "#000e11",
    "sideBar.foreground": "#8fe8f4",
    "statusBar.background": "#00242b",
    "statusBar.foreground": "#8fe8f4",
    "panel.background": "#000e11",
    "panel.border": "#000000a8",
    "button.background": "#00373f",
    "button.foreground": "#001419",
    "input.background": "#002028",
    "input.foreground": "#8fe8f4",
    "terminal.background": "#001419",
    "terminal.foreground": "#8fe8f4",
    "terminal.ansiBlack": "#000000",
    "terminal.ansiRed": "#e16d58",
    "terminal.ansiGreen": "#66dc84",
    "terminal.ansiYellow": "#e3cb6d",
    "terminal.ansiBlue": "#7de7f6",
    "terminal.ansiMagenta": "#f07ca3",
    "terminal.ansiCyan": "#5fd6e4",
    "terminal.ansiWhite": "#f5fdff",
    "terminal.ansiBrightBlack": "#0a8c9e",
    "terminal.ansiBrightRed": "#ee8b78",
    "terminal.ansiBrightGreen": "#8de6a6",
    "terminal.ansiBrightYellow": "#ebd998",
    "terminal.ansiBrightBlue": "#b6f4fb",
    "terminal.ansiBrightMagenta": "#f5a4c1",
    "terminal.ansiBrightCyan": "#9ae7f0",
    "terminal.ansiBrightWhite": "#b7f5fc",
    "gitDecoration.addedResourceForeground": "#66dc84",
    "gitDecoration.modifiedResourceForeground": "#e3cb6d",
    "gitDecoration.deletedResourceForeground": "#e33455",
    "editorError.foreground": "#e33455",
    "editorWarning.foreground": "#dd9b6f",
    "editorInfo.foreground": "#e26a89",
    "editorHint.foreground": "#2d909e"
  },
  "semanticTokenColors": {
    "class": "#74d68f",
    "enum": "#74d68f",
    "function": "#7de7f6",
    "method": "#7de7f6",
    "namespace": "#7de7f6",
    "parameter": "#f07ca3",
    "property": "#87eaf5",
    "type": "#74d68f",
    "variable": "#e9f2f4",
    "variableReadOnly": "#e16d58"
  },
  "tokenColors": [
    {
      "scope": [
        "comment"
      ],
      "settings": {
        "foreground": "#2d909e"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#e3cb6d"
      }
    },
    {
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#f07ca3"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#e16d58"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#7de7f6"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type"
      ],
      "settings": {
        "foreground": "#74d68f"
      }
    },
    {
      "scope": [
        "entity.name.class",
        "support.class",
        "entity.name.type.class"
      ],
      "settings": {
        "foreground": "#74d68f"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "meta.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#7de7f6"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter",
        "variable.other.readwrite.alias"
      ],
      "settings": {
        "foreground": "#f07ca3"
      }
    },
    {
      "scope": [
        "variable.object.property",
        "variable.other.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#87eaf5"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "constant.other",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#e16d58"
      }
    },
    {
      "scope": [
        "support.variable",
        "variable.language",
        "variable.language.this",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#e3cb6d"
      }
    },
    {
      "scope": [
        "entity.name.function.constructor",
        "meta.class-method.js entity.name.function"
      ],
      "settings": {
        "foreground": "#74d68f"
      }
    },
    {
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.key-value"
      ],
      "settings": {
        "foreground": "#87eaf5"
      }
    },
    {
      "scope": [
        "variable"
      ],
      "settings": {
        "foreground": "#e9f2f4"
      }
    }
  ]
}