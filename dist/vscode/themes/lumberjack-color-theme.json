{
  "$schema": "vscode://schemas/color-theme",
  "name": "Lumberjack dark",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "foreground": "#d5dfe7",
    "focusBorder": "#5d9ee6",
    "editor.background": "#0b0f14",
    "editor.foreground": "#d5dfe7",
    "editorLineNumber.foreground": "#3a4d5f",
    "editorLineNumber.activeForeground": "#b7c7d4",
    "editorCursor.foreground": "#dcc257",
    "editor.selectionBackground": "#2f6fb34d",
    "editor.findMatchBackground": "#b0682b59",
    "editor.lineHighlightBackground": "#ffffff0d",
    "activityBar.background": "#11161c",
    "activityBar.foreground": "#d5dfe7",
    "sideBar.background": "#172029",
    "sideBar.foreground": "#d5dfe7",
    "statusBar.background": "#11161c",
    "statusBar.foreground": "#d5dfe7",
    "panel.background": "#172029",
    "panel.border": "#1f2b36",
    "button.background": "#2f6fb3",
    "button.foreground": "#0b0f14",
    "input.background": "#1f2b36",
    "input.foreground": "#d5dfe7",
    "terminal.background": "#0b0f14",
    "terminal.foreground": "#d5dfe7",
    "terminal.ansiBlack": "#11161c",
    "terminal.ansiRed": "#e45a6c",
    "terminal.ansiGreen": "#58c985",
    "terminal.ansiYellow": "#dcc257",
    "terminal.ansiBlue": "#5d9ee6",
    "terminal.ansiMagenta": "#c67add",
    "terminal.ansiCyan": "#59c9d8",
    "terminal.ansiWhite": "#d5dfe7",
    "terminal.ansiBrightBlack": "#587088",
    "terminal.ansiBrightRed": "#ff9dad",
    "terminal.ansiBrightGreen": "#97e6b1",
    "terminal.ansiBrightYellow": "#f7e08e",
    "terminal.ansiBrightBlue": "#9cc8ff",
    "terminal.ansiBrightMagenta": "#e7b5f4",
    "terminal.ansiBrightCyan": "#9deaf2",
    "terminal.ansiBrightWhite": "#ffffff",
    "gitDecoration.addedResourceForeground": "#58c985",
    "gitDecoration.modifiedResourceForeground": "#dcc257",
    "gitDecoration.deletedResourceForeground": "#e45a6c",
    "editorError.foreground": "#e45a6c",
    "editorWarning.foreground": "#dcc257",
    "editorInfo.foreground": "#5d9ee6",
    "editorHint.foreground": "#58c985"
  },
  "semanticTokenColors": {
    "class": "#58c985",
    "enum": "#58c985",
    "function": "#59c9d8",
    "method": "#59c9d8",
    "namespace": "#59c9d8",
    "parameter": "#edf2f7",
    "property": "#5d9ee6",
    "type": "#58c985",
    "variable": "#edf2f7",
    "variableReadOnly": "#e39552"
  },
  "tokenColors": [
    {
      "scope": [
        "comment"
      ],
      "settings": {
        "foreground": "#587088"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#dcc257"
      }
    },
    {
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#c67add"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#e39552"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#59c9d8"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type"
      ],
      "settings": {
        "foreground": "#58c985"
      }
    },
    {
      "scope": [
        "variable"
      ],
      "settings": {
        "foreground": "#edf2f7"
      }
    }
  ]
}