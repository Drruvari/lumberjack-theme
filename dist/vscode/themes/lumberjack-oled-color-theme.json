{
  "$schema": "vscode://schemas/color-theme",
  "name": "Lumberjack oled",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "foreground": "#d3dde5",
    "disabledForeground": "#5d7080",
    "focusBorder": "#95d4e2",
    "editor.background": "#000000",
    "editor.foreground": "#d3dde5",
    "editorLineNumber.foreground": "#44525f",
    "editorLineNumber.activeForeground": "#acbcc9",
    "editorCursor.foreground": "#ecd98f",
    "editor.selectionBackground": "#2f7d8a4d",
    "editor.findMatchBackground": "#d9bf5852",
    "editor.lineHighlightBackground": "#ffffff10",
    "activityBar.background": "#0d1114",
    "activityBar.foreground": "#d3dde5",
    "sideBar.background": "#151b20",
    "sideBar.foreground": "#d3dde5",
    "statusBar.background": "#0d1114",
    "statusBar.foreground": "#d3dde5",
    "panel.background": "#151b20",
    "panel.border": "#1d252c",
    "button.background": "#2f7d8a",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#1d252c",
    "button.secondaryBackground": "#1d252c",
    "button.secondaryForeground": "#d3dde5",
    "button.secondaryHoverBackground": "#1d252c",
    "button.border": "#1d252c",
    "input.background": "#1d252c",
    "input.foreground": "#d3dde5",
    "terminal.background": "#000000",
    "terminal.foreground": "#d3dde5",
    "terminal.ansiBlack": "#151b20",
    "terminal.ansiRed": "#dd5b68",
    "terminal.ansiGreen": "#56b984",
    "terminal.ansiYellow": "#d9bf58",
    "terminal.ansiBlue": "#5b90d1",
    "terminal.ansiMagenta": "#b074ca",
    "terminal.ansiCyan": "#55aec0",
    "terminal.ansiWhite": "#d3dde5",
    "terminal.ansiBrightBlack": "#5d7080",
    "terminal.ansiBrightRed": "#f29aa4",
    "terminal.ansiBrightGreen": "#95dab2",
    "terminal.ansiBrightYellow": "#ecd98f",
    "terminal.ansiBrightBlue": "#9fc0ea",
    "terminal.ansiBrightMagenta": "#d7afe7",
    "terminal.ansiBrightCyan": "#95d4e2",
    "terminal.ansiBrightWhite": "#ffffff",
    "gitDecoration.addedResourceForeground": "#56b984",
    "gitDecoration.modifiedResourceForeground": "#d9bf58",
    "gitDecoration.deletedResourceForeground": "#dd5b68",
    "editorError.foreground": "#dd5b68",
    "editorWarning.foreground": "#da9652",
    "editorInfo.foreground": "#5b90d1",
    "editorHint.foreground": "#56b984"
  },
  "semanticTokenColors": {
    "class": "#56b984",
    "enum": "#56b984",
    "function": "#95d4e2",
    "method": "#95d4e2",
    "namespace": "#95d4e2",
    "parameter": "#56b984",
    "property": "#5b90d1",
    "type": "#56b984",
    "variable": "#d3dde5",
    "variableReadOnly": "#da9652"
  },
  "tokenColors": [
    {
      "scope": [
        "comment"
      ],
      "settings": {
        "foreground": "#5d7080"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#ecd98f"
      }
    },
    {
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#56b984"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#da9652"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#95d4e2"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type"
      ],
      "settings": {
        "foreground": "#56b984"
      }
    },
    {
      "scope": [
        "entity.name.class",
        "support.class",
        "entity.name.type.class"
      ],
      "settings": {
        "foreground": "#56b984"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "meta.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#95d4e2"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter",
        "variable.other.readwrite.alias"
      ],
      "settings": {
        "foreground": "#56b984"
      }
    },
    {
      "scope": [
        "variable.object.property",
        "variable.other.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#5b90d1"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "constant.other",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#da9652"
      }
    },
    {
      "scope": [
        "support.variable",
        "variable.language",
        "variable.language.this",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#ecd98f"
      }
    },
    {
      "scope": [
        "entity.name.function.constructor",
        "meta.class-method.js entity.name.function"
      ],
      "settings": {
        "foreground": "#56b984"
      }
    },
    {
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.key-value"
      ],
      "settings": {
        "foreground": "#5b90d1"
      }
    },
    {
      "scope": [
        "variable"
      ],
      "settings": {
        "foreground": "#d3dde5"
      }
    }
  ]
}