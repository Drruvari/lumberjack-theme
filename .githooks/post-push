#!/usr/bin/env sh
set -eu

remote_name="${1:-}"

if [ "$remote_name" != "origin" ]; then
  exit 0
fi

pushed_main=0
while read -r _local_ref _local_sha remote_ref _remote_sha; do
  if [ "$remote_ref" = "refs/heads/main" ]; then
    pushed_main=1
  fi
done

if [ "$pushed_main" -ne 1 ]; then
  exit 0
fi

if [ "${LUMBERJACK_SKIP_POST_PUSH:-0}" = "1" ]; then
  exit 0
fi

echo "[post-push] Syncing main and packaging latest VSIX..."
node scripts/sync-after-push.mjs
