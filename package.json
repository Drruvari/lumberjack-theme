{
  "name": "lumberjack-theme",
  "displayName": "Lumberjack Theme",
  "description": "A high-contrast dark theme with a cyber-lumberjack palette for VS Code and Cursor.",
  "version": "0.0.2",
  "type": "module",
  "publisher": "drruvari",
  "license": "MIT",
  "icon": "assets/lumberjack.png",
  "scripts": {
    "build": "npm run build:engine",
    "vscode:prepublish": "npm run build",
    "build:engine": "node --experimental-strip-types src/cli/build.ts",
    "validate:engine": "node --experimental-strip-types src/cli/validate.ts",
    "targets": "node --experimental-strip-types src/cli/list-targets.ts",
    "package": "npm run build && vsce package",
    "tokens:diff": "node scripts/diff-theme-keys.mjs dist/vscode/themes/lumberjack-color-theme.json tmp/generated-theme.json"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "dark theme",
    "lumberjack",
    "cursor",
    "vscode"
  ],
  "galleryBanner": {
    "color": "#00171a",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/drruvari/lumberjack-theme.git"
  },
  "bugs": {
    "url": "https://github.com/drruvari/lumberjack-theme/issues"
  },
  "homepage": "https://github.com/drruvari/lumberjack-theme#readme",
  "contributes": {
    "themes": [
      {
        "label": "Lumberjack Theme",
        "uiTheme": "vs-dark",
        "path": "./dist/vscode/themes/lumberjack-color-theme.json"
      }
    ]
  }
}
